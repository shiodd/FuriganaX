{
  "manifest_version": 3,
  "name": "FuriganaX",
  "version": "1.0.0",
  "description": "在 X(Twitter) 上浏览日文推文时，点击按钮为汉字标注假名",
  "permissions": [],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "kuromoji.js", "dict/*"],
      "matches": ["https://twitter.com/*", "https://x.com/*"]
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}
